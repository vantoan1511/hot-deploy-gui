{
  "applicationId": "com.github.vantoan1511.hotdeploygui",
  "version": "1.1.1",
  "defaultMode": "window",
  "documentRoot": "/src/dist/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "nativeAllowList": [
    "app.*",
    "os.*",
    "filesystem.*",
    "storage.*"
  ],
  "modes": {
    "window": {
      "title": "Hot Deploy GUI",
      "width": 1280,
      "height": 800,
      "minWidth": 900,
      "minHeight": 600,
      "icon": "/src/public/favicon.ico",
      "enableInspector": false
    }
  },
  "cli": {
    "binaryName": "hot-deploy-gui",
    "resourcesPath": "/src/dist/",
    "extensionsPath": "/extensions/",
    "binaryVersion": "6.5.0",
    "clientVersion": "6.5.0",
    "frontendLibrary": {
      "patchFile": "/src/index.html",
      "devUrl": "http://localhost:5173",
      "projectPath": "/src",
      "initCommand": "npm install",
      "devCommand": "npm run dev",
      "buildCommand": "npm run build"
    }
  }
}